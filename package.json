{
  "name": "bluemachines-tiger-onboarding",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "preinstall": "node -e \"const fs=require('fs');['package-lock.json','yarn.lock'].forEach(f=>{try{fs.unlinkSync(f)}catch{}});const ua=process.env.npm_config_user_agent||'';if(!/pnpm\\//.test(ua)){console.error('Use pnpm instead');process.exit(1)}\"",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "build:prototype": "pnpm --filter @workspace/tiger-prototype run build",
    "build:netlify": "pnpm --filter @workspace/tiger-prototype run build",
    "dev:prototype": "pnpm --filter @workspace/tiger-prototype run dev",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "@netlify/functions": "^3.1.0",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3"
  }
}
